add_lines(y = ~`Reservas mensuales`, name = "Reservas Brutas",
line = list(color = "#00829A", width = 3)) |>
add_annotations(x = max(df_1$fecha), y = tail(df_1$`Reservas mensuales`, 1),
text = formatC(tail(df_1$`Reservas mensuales`, 1), format = "f", digits = 0, big.mark = ","),
showarrow = FALSE, font = list(color = "#00829A", size = 12)) |>
