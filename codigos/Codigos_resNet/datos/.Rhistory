fecha  = floor_date(Fecha, "month"),
Último = Último / 10000
) |>
arrange(Fecha) |>
group_by(fecha) |>
slice_tail(n = 1) |>
ungroup() |>
select(fecha, Último)
swap_china <- tibble(
fecha  = seq(as.Date("2020-01-01"), by = "month", length.out = 75),
yuanes = 130000000
) |>
left_join(tc_yuan, by = "fecha") |>
mutate(swap_usd = (yuanes / Último) / 1000) |>
select(fecha, swap_usd)
# Reservas brutas
reservas <- read_excel("reservas.xlsx") |>
mutate(fecha = floor_date(as.Date(Fecha), "month")) |>
select(fecha, `Reservas mensuales`)
# Merge final
df_1 <- deuda_multi |>
left_join(encajes |> select(fecha, dep_Nac_ext, `otros pasivos_usd`, encajes_ext), by = "fecha") |>
left_join(reservas,   by = "fecha") |>
left_join(swap_china, by = "fecha") |>
left_join(bop |> select(fecha, bop_año), by = "fecha") |>
filter(fecha >= as.Date("2020-01-01"), fecha <= as.Date("2026-01-01")) |>
mutate(across(c(encajes_ext, swap_usd, bop_año, dep_Nac_ext, `otros pasivos_usd`, deuda_mult),
\(x) replace_na(x, 0)),
`otros pasivos_usd` = `otros pasivos_usd` - swap_usd) |>
select(fecha, `Reservas mensuales`, encajes_ext, swap_usd, bop_año,
dep_Nac_ext, `otros pasivos_usd`, deuda_mult) |>
mutate(
Res_net       = `Reservas mensuales` - encajes_ext - swap_usd - bop_año - dep_Nac_ext - `otros pasivos_usd`,
Res_Super_net = Res_net - deuda_mult
)
# Gráfico
color_net   <- "#1f4e79"
color_super <- "#a61c1c"
plot_ly(df_1, x = ~fecha) |>
add_lines(y = ~Res_net,       name = "Reservas Netas",
line = list(color = color_net,   width = 3)) |>
add_lines(y = ~Res_Super_net, name = "Reservas Super Netas",
line = list(color = color_super, width = 3)) |>
add_segments(x = min(df_1$fecha), xend = max(df_1$fecha),
y = 0, yend = 0,
line = list(dash = "dash", color = "black", opacity = 0.6),
showlegend = FALSE) |>
add_annotations(x = max(df_1$fecha), y = tail(df_1$Res_net, 1),
text = formatC(tail(df_1$Res_net, 1), format = "f", digits = 0, big.mark = ","),
showarrow = FALSE, font = list(color = color_net, size = 12)) |>
add_annotations(x = max(df_1$fecha), y = tail(df_1$Res_Super_net, 1),
text = formatC(tail(df_1$Res_Super_net, 1), format = "f", digits = 0, big.mark = ","),
showarrow = FALSE, font = list(color = color_super, size = 12)) |>
layout(
title  = list(text = "Reservas Internacionales del BCRA", x = 0,
font = list(size = 18)),
yaxis  = list(title = "Millones de USD", tickformat = ",",
showgrid = TRUE, gridcolor = "rgba(0,0,0,0.1)"),
xaxis  = list(showgrid = FALSE),
legend = list(orientation = "h", y = 1.05, x = 0),
margin = list(l = 40, r = 20, t = 60, b = 40)
)
